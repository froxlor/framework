{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "froxlor/mail",
    "type": "library",
    "description": "The froxlor mail package.",
    "keywords": [
        "froxlor",
        "management",
        "panel"
    ],
    "homepage": "https://www.froxlor.org",
    "license": "proprietary",
    "authors": [
        {
            "name": "Michael Kaufmann",
            "email": "d00p@froxlor.org",
            "role": "Lead Developer"
        },
        {
            "name": "Maurice Preuß",
            "email": "envoyr@froxlor.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "froxlor/domain": "*",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Froxlor\\Mail\\": "src/",
            "Froxlor\\Mail\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "froxlor": {
            "type": "package"
        },
        "laravel": {
            "providers": [
                "Froxlor\\Mail\\Providers\\EventServiceProvider",
                "Froxlor\\Mail\\Providers\\FroxlorMailServiceProvider"
            ]
        }
    }
}
