{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "froxlor/ftp",
    "type": "library",
    "description": "The froxlor ftp package.",
    "keywords": [
        "froxlor",
        "management",
        "panel"
    ],
    "homepage": "https://www.froxlor.org",
    "license": "proprietary",
    "authors": [
        {
            "name": "Michael Kaufmann",
            "email": "d00p@froxlor.org",
            "role": "Lead Developer"
        },
        {
            "name": "Maurice Preuß",
            "email": "envoyr@froxlor.org",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "froxlor/core": "*",
        "froxlor/ui": "*",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Froxlor\\Ftp\\": "src/"
        }
    },
    "extra": {
        "froxlor": {
            "type": "package"
        },
        "laravel": {
            "providers": [
                "Froxlor\\Ftp\\Providers\\FroxlorFtpServiceProvider"
            ]
        }
    }
}
